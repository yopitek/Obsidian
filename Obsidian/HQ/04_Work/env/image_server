 Mac Mini Setup (3 steps)
 Step 1 — Save the MCP script
 mkdir -p ~/scripts
 cat > ~/scripts/gx10_image_mcp.py << 'EOF'
 #!/usr/bin/env python3
  """MCP server for Mac Mini — calls GX10 image API over LAN."""
   import asyncio, base64, json, os, re, urllib.request, urllib.error
   from mcp.server.fastmcp import FastMCP
   
   GX10_API = "http://192.168.1.228:8002/v1/images/generations"
   SAVE_DIR = os.path.expanduser("~/Pictures/AI-Generated")
   TIMEOUT  = 600
   
   mcp = FastMCP("gx10-image-gen")
   
   def _next_filename(prompt):
       slug = re.sub(r"[^a-zA-Z0-9]+", "_", prompt[:40]).strip("_").lower()
       os.makedirs(SAVE_DIR, exist_ok=True)
       base = os.path.join(SAVE_DIR, slug)
       path = f"{base}.png"
       i = 1
       while os.path.exists(path):
           path = f"{base}_{i}.png"; i += 1
       return path
   
   def _call_api(prompt, size):
       payload = json.dumps({"prompt": prompt, "size": size, "n": 1,
                             "response_format": "b64_json"}).encode()
       req = urllib.request.Request(GX10_API, data=payload,
             headers={"Content-Type": "application/json"}, method="POST")
       with urllib.request.urlopen(req, timeout=TIMEOUT) as r:
           body = json.loads(r.read())
       return base64.b64decode(body["data"][0]["b64_json"])
   
   @mcp.tool()
   async def generate_image(prompt: str, size: str = "1024x1024") -> str:
       """Generate an image using GX10 FLUX.1-dev over LAN. size e.g. 512x512"""
       loop = asyncio.get_event_loop()
       img_bytes = await loop.run_in_executor(None, _call_api, prompt, size)
       path = _next_filename(prompt)
       with open(path, "wb") as f: f.write(img_bytes)
       return f"Image saved to: {path}  ({len(img_bytes)//1024} KB)"
   
   if __name__ == "__main__":
       mcp.run()
   EOF
   chmod +x ~/scripts/gx10_image_mcp.py
   pip3 install mcp

  Step 2 — Add to Claude Code MCP config

   # Edit ~/.claude.json  (create if not exists)
   cat > ~/.claude.json << 'EOF'
   {
     "mcpServers": {
       "gx10-image-gen": {
         "command": "python3",
         "args": ["/Users/YOUR_USERNAME/scripts/gx10_image_mcp.py"],
         "timeout": 600000
       }
     }
   }
   EOF
   Replace YOUR_USERNAME with your Mac username (whoami)
  Step 3 — Test connection
   curl http://192.168.1.228:8002/health
   # Should return: {"status":"ok","comfyui":true}
  -----------------------------------------------------------------------------------------------
  Then in Claude Code on Mac Mini, just say:
   generate an image of a sunset over mountains
  Claude will call generate_image() → image saves to ~/Pictures/AI-Generated/